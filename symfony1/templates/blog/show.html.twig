<h1>{{ post.title }}</h1>
<p>Category: {{ post.category.name }}</p>
<p>{{ post.content }}</p>
<p>Tags:
    {% for tag in post.tags %}
        <span>{{ tag.name }}</span>
    {% endfor %}
</p>
<p>Published: {{ post.createdAt|date('Y-m-d H:i') }}</p>
<a href="{{ path('blog_index') }}">Back to blog</a>