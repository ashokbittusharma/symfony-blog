<h1>Blog</h1>

{% for post in posts %}
    <article>
        <h2><a href="{{ path('blog_show', {'id': post.id}) }}">{{ post.title }}</a></h2>
        <p>Category: {{ post.category.name }}</p>
        <p>{{ post.content|slice(0, 200) }}...</p>
        <p>Tags: 
            {% for tag in post.tags %}
                <span>{{ tag.name }}</span>
            {% endfor %}
        </p>
    </article>
{% else %}
    <p>No posts found.</p>
{% endfor %}